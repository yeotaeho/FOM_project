# isolation data: backend1/metrics/isolation/.gitignore

# --- backend1 / metrics — ROM (영상·추출 JSON) ---
backend1/metrics/rom/**/video_data/*
!backend1/metrics/rom/**/video_data/.gitkeep
!backend1/metrics/rom/**/video_data/.gitignore
